# Telegram — get from @BotFather after /newbot
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Gemini — https://ai.google.dev/gemini-api/keys
GEMINI_API_KEY=your-gemini-api-key-here

# Postgres connection string
# Local:  postgresql+asyncpg://user:password@localhost:5432/dbname
# Hosted: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/build_challenge
