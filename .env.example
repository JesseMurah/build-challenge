# Telegram — get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Postgres — sync psycopg2 driver (no +asyncpg)
# Local:  postgresql://postgres:postgres@localhost:5432/your_db
# Hosted: postgresql://user:password@host:5432/your_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/build_challenge

# Public URL Telegram will POST webhook updates to (no trailing slash)
# Local dev: run `ngrok http 8000` and paste the https:// URL here
WEBHOOK_URL=https://xxxx.ngrok-free.app

# Hour of day in UTC to deliver the daily Digest (0-23, default 8 = 08:00 UTC)
DIGEST_HOUR=8
